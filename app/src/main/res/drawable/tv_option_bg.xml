<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#6C5CE7"/>
            <corners android:radius="18dp"/>
            <stroke
                android:width="2dp"
                android:color="#2E3350"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#1E2235"/>
            <corners android:radius="18dp"/>
            <stroke
                android:width="2dp"
                android:color="#2E3350"/>
        </shape>
    </item>

</selector>