<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F1A">

    <!-- Background Glow -->
    <View
        android:layout_width="700dp"
        android:layout_height="700dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_glow_prim"
        android:alpha="0.15" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="40dp"
            android:focusableInTouchMode="true"
            android:descendantFocusability="afterDescendants">

            <!-- Title -->
            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW TO PLAY"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:letterSpacing="0.1"
                android:layout_marginBottom="32dp" />

            <!-- TOP ROW (3 CARDS) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="3">

                <!-- CARD 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    android:layout_margin="12dp"
                    android:background="@drawable/card_bg">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/multiplayer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select a Category"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Then select players and enter names."
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- CARD 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    android:layout_margin="12dp"
                    android:background="@drawable/card_bg">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/eye" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Read the Statement"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Is it real or made up?"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- CARD 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    android:layout_margin="12dp"
                    android:background="@drawable/card_bg">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/message" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Discuss"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Debate and bluff!"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- BOTTOM ROW (CENTERED CARD) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="340dp"
                    android:layout_height="220dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_bg">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/game" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vote True or Lie"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Highest score wins!"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This game is for fun. Don't ruin friendships over facts."
                android:textSize="13sp"
                android:textColor="#777777"
                android:layout_marginTop="32dp" />

            <!-- Back Button -->
            <Button
                android:id="@+id/btnBacktoMenu"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Back to Menu"
                android:layout_marginTop="24dp"
                android:background="@drawable/btn_secondary"
                android:textColor="@android:color/white"
                android:focusable="true"
                android:focusableInTouchMode="true" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>