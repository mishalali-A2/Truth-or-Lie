<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0B0F1A"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/settingsRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="40dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Background Glow (Optional for consistency) -->
        <!-- Since it's a ScrollView, we might not want a fixed glow unless it's in a parent FrameLayout -->

        <!-- TITLE -->
        <TextView
            android:text="Settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textStyle="bold"
            android:layout_marginBottom="30dp"/>

        <!-- MUSIC CARD -->
        <LinearLayout
            android:id="@+id/musicOuterContainer"
            android:layout_width="600dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:clipChildren="false">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/music" />

                <TextView
                    android:text=" Music"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:layout_weight="1"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchMusic"
                    android:layout_width="67dp"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    app:thumbTint="@color/switch_thumb_color"
                    app:trackTint="@color/switch_track_color" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/musicContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="15dp">

                <!-- First Row: 3 genres -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:clipChildren="false">

                    <Button
                        android:id="@+id/chipPartyVibes"
                        style="@style/chip_music"
                        android:text="Party Vibes"
                        android:layout_weight="1"
                        android:layout_margin="4dp"/>

                    <Button
                        android:id="@+id/chipChillLounge"
                        style="@style/chip_selected_music"
                        android:text="Chill Lounge"
                        android:layout_weight="1"
                        android:layout_margin="4dp"/>

                    <Button
                        android:id="@+id/chipRetroArcade"
                        style="@style/chip_music"
                        android:text="Retro Arcade"
                        android:layout_weight="1"
                        android:layout_margin="4dp"/>

                </LinearLayout>

                <!-- Second Row: 2 genres -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:clipChildren="false">

                    <Button
                        android:id="@+id/chipEpicAdventure"
                        style="@style/chip_music"
                        android:text="Epic Adventure"
                        android:layout_weight="1"
                        android:layout_margin="4dp"/>

                    <Button
                        android:id="@+id/chipFunkyGroove"
                        style="@style/chip_music"
                        android:text="Funky Groove"
                        android:layout_weight="1"
                        android:layout_margin="4dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- TIMER CARD -->
        <LinearLayout
            android:id="@+id/timerContainer"
            android:layout_width="600dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:clipChildren="false">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/timer" />

                <TextView
                    android:text=" Timer (seconds)"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_marginTop="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipChildren="false">

                <Button
                    android:id="@+id/timer10"
                    style="@style/chip_timer"
                    android:text="10"
                    android:layout_margin="4dp"/>

                <Button
                    android:id="@+id/timer20"
                    style="@style/chip_timer_selected"
                    android:text="20"
                    android:layout_margin="4dp"/>

                <Button
                    android:id="@+id/timer30"
                    style="@style/chip_timer"
                    android:text="30"
                    android:layout_margin="4dp"/>

                <Button
                    android:id="@+id/timer40"
                    style="@style/chip_timer"
                    android:text="40"
                    android:layout_margin="4dp"/>

                <Button
                    android:id="@+id/timer50"
                    style="@style/chip_timer"
                    android:text="50"
                    android:layout_margin="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- OTHER APPS CARD -->
        <LinearLayout
            android:id="@+id/otherAppsCard"
            android:layout_width="600dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:clipChildren="false">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/game" />

                <TextView
                    android:text=" Other Apps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/otherAppsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="15dp"
                android:clipChildren="false" />
        </LinearLayout>

        <!-- OTHER SETTINGS CARD -->
        <LinearLayout
            android:id="@+id/otherSettings"
            android:layout_width="600dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Remove Ads -->
            <LinearLayout
                android:id="@+id/removeAds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:focusable="true"
                android:clickable="true"
                android:padding="8dp"
                android:clipChildren="false">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/star"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/optionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Remove Ads"/>

                    <TextView
                        style="@style/optionSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="One-time purchase"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Restore Purchases -->
            <LinearLayout
                android:id="@+id/restorePurchases"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:focusable="true"
                android:clickable="true"
                android:padding="8dp"
                android:clipChildren="false">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/sheild"/>

                <TextView
                    style="@style/optionText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="Restore Purchases"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"/>
            </LinearLayout>

