<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0B0F1A">

    <View
        android:id="@+id/focusAnchor"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:focusable="true"
        android:focusableInTouchMode="false" />


    <View
        android:id="@+id/barTimer"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="#00FFAA"
        android:layout_gravity="top" />


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="20dp"
        android:layout_gravity="top|end"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROUND 1/5"
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:layout_marginEnd="20dp" />

        <ImageView
            android:id="@+id/btnPause"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/pause"
            app:tint="#888888"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:alpha="0.7"/>

    </LinearLayout>

    <!-- Player name -->
    <TextView
        android:id="@+id/tvPlayer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player 1"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="120dp" />

    <!-- Statement -->
    <TextView
        android:id="@+id/tvStatement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Statement here"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:gravity="center"
        android:layout_margin="40dp"
        android:layout_gravity="center" />

    <!-- Timer countdown text -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20s"
        android:textColor="#FFA500"
        android:textSize="32sp"
        android:layout_gravity="center_horizontal|center_vertical"
        android:layout_marginTop="80dp" />

    <!-- Truth / Lie bottom panels -->
    <!-- Truth / Lie bottom panels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="horizontal"
        android:layout_gravity="bottom">

        <!-- TRUTH -->
        <FrameLayout
            android:id="@+id/frameTruth"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#123425">

            <!-- Top glow line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#00FFAA"
                android:layout_gravity="top"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="TRUTH"
                android:textColor="#00FFAA"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </FrameLayout>

        <!-- CENTER DIVIDER -->
        <View
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#1A1A1A" />

        <!-- LIE -->
        <FrameLayout
            android:id="@+id/frameLie"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#3B1A1F">

            <!-- Top glow line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#FF4444"
                android:layout_gravity="top"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="LIE"
                android:textColor="#FF4444"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </FrameLayout>

    </LinearLayout>

    <!-- Pause Overlay -->
    <FrameLayout
        android:id="@+id/pauseOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0B0F1A"
        android:visibility="gone">

        <!-- Center Card -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="40dp"
            android:background="@android:color/transparent">

            <!-- Pause Icon -->
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/pause"
                app:tint="#7C5CFF"
                android:layout_marginBottom="20dp"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Game Paused"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Press resume to continue"
                android:textSize="16sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="30dp" />

            <!-- Resume Button -->
            <Button
                android:id="@+id/btnResume"
                android:layout_width="220dp"
                android:layout_height="60dp"
                android:text="Resume"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="16dp"/>

            <!-- End Game Button -->
            <Button
                android:id="@+id/btnEndGame"
                android:layout_width="220dp"
                android:layout_height="60dp"
                android:text="End Game"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"/>

        </LinearLayout>
    </FrameLayout>

</FrameLayout>